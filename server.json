{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.obcraft/apiosk-mcp",
  "title": "Apiosk Connect",
  "description": "Discover, pay for, execute, and publish APIs through Apiosk.",
  "version": "1.7.0",
  "websiteUrl": "https://apiosk.com",
  "icons": [
    {
      "src": "https://mcp.apiosk.com/logo-optimized-light.png",
      "mimeType": "image/png",
      "sizes": ["2048x2048"]
    },
    {
      "src": "https://apiosk.com/logo.svg",
      "mimeType": "image/svg+xml",
      "sizes": ["any"]
    },
    {
      "src": "https://apiosk.com/apple-touch-icon.png",
      "mimeType": "image/png",
      "sizes": ["180x180"]
    }
  ],
  "repository": {
    "url": "https://github.com/obcraft/apiosk-mcp",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@apiosk/mcp",
      "version": "1.7.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "APIOSK_PRIVATE_KEY",
          "description": "Optional wallet private key for automatic x402 payments.",
          "isRequired": false,
          "isSecret": true,
          "format": "string"
        },
        {
          "name": "APIOSK_CONNECT_TOKEN",
          "description": "Optional dashboard-managed access token.",
          "isRequired": false,
          "isSecret": true,
          "format": "string"
        }
      ]
    },
    {
      "registryType": "pypi",
      "identifier": "apiosk-mcp",
      "version": "1.7.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "APIOSK_PRIVATE_KEY",
          "description": "Optional wallet private key for automatic x402 payments.",
          "isRequired": false,
          "isSecret": true,
          "format": "string"
        },
        {
          "name": "APIOSK_CONNECT_TOKEN",
          "description": "Optional dashboard-managed access token.",
          "isRequired": false,
          "isSecret": true,
          "format": "string"
        }
      ]
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://mcp.apiosk.com/mcp"
    }
  ],
  "_meta": {
    "com.apiosk": {
      "tags": ["payments", "finance", "x402", "commerce", "crypto"],
      "categories": ["payments", "finance"]
    }
  }
}
